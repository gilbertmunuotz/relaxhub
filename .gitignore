# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/

# Local configuration (SDK path — machine-specific)
local.properties

# Android Studio / IntelliJ IDEA
*.iml
.idea/
.idea/caches/
.idea/libraries/
.idea/modules.xml
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml

# Keystore files — never commit signing keys
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2+
.externalNativeBuild/
.cxx/

# Google Services (uncomment if you add Firebase and use a local-only config)
# google-services.json

# OS-specific files
.DS_Store
Thumbs.db

# Log files
*.log

# Android Studio captures folder
captures/

# Kotlin
.kotlin/

# Signing config (if you keep secrets in a separate file)
signing.properties
