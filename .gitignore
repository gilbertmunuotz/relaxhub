# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle (frontend)
.gradle/
build/

# Maven (backend)
target/

# Local configuration (SDK path — machine-specific)
local.properties

# Android Studio / IntelliJ IDEA
*.iml
.idea/
.vscode/

# Keystore files — never commit signing keys
*.jks
*.keystore
signing.properties

# External native build folder generated in Android Studio 2.2+
.externalNativeBuild/
.cxx/

# Google Services (uncomment if you add Firebase and use a local-only config)
# google-services.json

# OS-specific files
.DS_Store
Thumbs.db

# Log files
*.log

# Android Studio captures folder
captures/

# Kotlin
.kotlin/

# Environment and secrets
.env
.env.*
!.env.example
application-local.yaml
application-local.yml
