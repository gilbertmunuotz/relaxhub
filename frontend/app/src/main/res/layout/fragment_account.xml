<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/padding_screen"
        android:paddingTop="@dimen/padding_medium"
        android:paddingEnd="@dimen/padding_screen"
        android:paddingBottom="@dimen/padding_xl">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/account_subtitle"
            android:textAppearance="@style/TextAppearance.Relaxhub.BodySecondary" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_large"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/padding_medium">

                <TextView
                    android:id="@+id/accountAvatarText"
                    android:layout_width="@dimen/settings_avatar_size"
                    android:layout_height="@dimen/settings_avatar_size"
                    android:background="@drawable/bg_settings_avatar"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.Relaxhub.Label"
                    android:textColor="@color/primary"
                    tools:text="J" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_medium"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/accountName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Relaxhub.Label"
                        tools:text="John Doe" />

                    <TextView
                        android:id="@+id/accountEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="@style/TextAppearance.Relaxhub.Caption"
                        tools:text="johndoe@gmail.com" />

                    <TextView
                        android:id="@+id/accountStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:textAppearance="@style/TextAppearance.Relaxhub.Caption"
                        android:textColor="@color/text_secondary"
                        tools:text="Profile synced with server" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_xl"
            android:text="@string/settings_section_activity"
            android:textAppearance="@style/TextAppearance.Relaxhub.Section" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include
                    android:id="@+id/openReceiptRow"
                    layout="@layout/item_settings_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="@dimen/settings_divider_inset"
                    android:background="@color/divider" />

                <include
                    android:id="@+id/openFeedbackRow"
                    layout="@layout/item_settings_row" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="@dimen/settings_divider_inset"
                    android:background="@color/divider" />

                <include
                    android:id="@+id/openComplaintsRow"
                    layout="@layout/item_settings_row" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/logoutButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_xl"
            android:text="@string/action_logout"
            android:textColor="@color/error"
            app:rippleColor="@color/primary_light"
            app:strokeColor="@color/error" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
