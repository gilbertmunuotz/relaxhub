<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/homeHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_header"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_screen"
            android:paddingEnd="@dimen/padding_screen"
            android:paddingBottom="@dimen/padding_xl">

            <TextView
                android:id="@+id/homeGreetingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Relaxhub.Display"
                android:textColor="@color/white"
                tools:text="Good evening, John" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:alpha="0.88"
                android:text="@string/home_subtitle"
                android:textAppearance="@style/TextAppearance.Relaxhub.Body"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/homeEmailChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_medium"
                android:background="@drawable/bg_email_chip"
                android:paddingStart="@dimen/padding_medium"
                android:paddingTop="@dimen/spacing_xs"
                android:paddingEnd="@dimen/padding_medium"
                android:paddingBottom="@dimen/spacing_xs"
                android:textAppearance="@style/TextAppearance.Relaxhub.Caption"
                android:textColor="@color/white"
                tools:text="johndoe@gmail.com" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_screen"
            android:paddingTop="@dimen/padding_large"
            android:paddingEnd="@dimen/padding_screen"
            android:paddingBottom="@dimen/padding_xl">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_quick_actions"
                android:textAppearance="@style/TextAppearance.Relaxhub.Section" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_medium"
                android:baselineAligned="false"
                android:minHeight="@dimen/quick_action_card_height"
                android:orientation="horizontal">

                <include
                    android:id="@+id/openMapAction"
                    layout="@layout/item_home_quick_action"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/openReceiptAction"
                    layout="@layout/item_home_quick_action"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:layout_weight="1" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_xl"
                android:text="@string/receipt_history_title"
                android:textAppearance="@style/TextAppearance.Relaxhub.Section" />

            <TextView
                android:id="@+id/recentVisitsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_medium"
                android:text="@string/receipt_history_empty"
                android:textAppearance="@style/TextAppearance.Relaxhub.BodySecondary" />

            <LinearLayout
                android:id="@+id/recentVisitsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_medium"
                android:orientation="vertical"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
